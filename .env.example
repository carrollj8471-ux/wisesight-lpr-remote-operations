GOOGLE_DEVICE_ACCESS_PROJECT_ID=your-device-access-project-id
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token
GOOGLE_ACCESS_TOKEN=optional-short-lived-access-token
GOOGLE_SDM_DEVICE=enterprises/your-device-access-project-id/devices/your-device-id
GOOGLE_SDM_TIMEOUT=30
WISESIGHT_DB_PATH=lpr_operations.db

# Remote LPR operations agent
OPS_SERVER_URL=http://127.0.0.1:5000/api/ops/heartbeat
OPS_AGENT_TOKEN=change-this-shared-agent-token
SITE_ID=surface-lot-main
SITE_NAME=Main Surface Lot
DEVICE_ID=jetson-j3011-01
LPR_SERVICE=lpr-engine
REMOTE_ACCESS_SERVICE=teamviewerd
CAMERA_RTSP_URL=rtsp://user:password@camera-ip/stream
LPR_SNAPSHOT_DIR=/var/lib/wisesight/snapshots
HEARTBEAT_INTERVAL=60
